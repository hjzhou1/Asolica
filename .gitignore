# ==============================
# Asolica 发卡系统 - Git 忽略规则
# 仅推送源码到 GitHub，过滤一切非源码文件
# ==============================

# --- 依赖 ---
node_modules/

# --- 环境变量（含密钥，绝对不能提交）---
.env
.env.local
.env.*.local
.env.production
.env.staging

# --- 数据库与运行时数据 ---
server/data/

# --- 用户上传文件 ---
server/uploads/
!server/uploads/.gitkeep

# --- 备份文件 ---
server/backups/

# --- 前端构建产物（源码仓库不提交 dist，用 Release 分发）---
web/dist/
web/.vite/

# --- 打包产物（用 GitHub Release 分发，不入仓库）---
*.zip
*.tar.gz

# --- Mac 系统文件 ---
.DS_Store
__MACOSX/
._*

# --- Windows 系统文件 ---
Thumbs.db
Desktop.ini

# --- IDE / 编辑器配置 ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- 日志文件 ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
server/logs/

# --- 缓存文件 ---
.eslintcache
.prettiercache
coverage/
.vite/

# --- 临时/归档 ---
web-backup-*/
_archive/
.workbuddy/

# --- PM2 日志（本地运行产生）---
pm2-*.log
