# ===== 阿索利卡发卡平台 - 环境变量配置 =====
# 复制本文件为 .env 并修改对应值
# 如果不复制，系统首次启动时会自动创建 .env 并生成随机密钥

# ---- 必填 ----

# JWT 签名密钥（至少 32 位随机字符串）
# 留空则首次启动时自动生成并写回此文件
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ---- 可选 ----

# 服务端口
PORT=3200

# CORS 允许的源（多个用逗号分隔，留空则允许所有来源）
# 生产环境建议设为实际域名，如: https://asolica.example.com
CORS_ORIGINS=

# 运行环境 (development / production)
NODE_ENV=production

# 站点基础 URL（用于支付回调地址生成）
# ⚠️ 生产环境必须设置！不设则从请求头推导（反向代理下可能得到 127.0.0.1）
# 格式: https://your-domain.com（不要带末尾斜杠）
BASE_URL=

# 订单超时时间（分钟），默认 30 分钟
# ORDER_EXPIRE_MINUTES=30

# 管理员默认密码（首次初始化时使用，不设则生成随机密码并打印到控制台）
# 仅在数据库为空（首次启动）时生效，已存在管理员账号时忽略
# ADMIN_DEFAULT_PASSWORD=

# ---- 备份 ----
# backup.js 不需要环境变量，直接 node backup.js 即可
# 建议 cron: 0 2 * * * cd /path/to/server && node backup.js
